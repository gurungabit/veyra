                        { "id": "borgars-7518-accept", "kind": "acceptQuest", "questId": 7518 },
                        {
                          "id": "borgars-7518-time-fragments",
                          "kind": "repeat",
                          "iterations": 12,
                          "actions": [
                            { "id": "borgars-7518-hunt", "kind": "hunt", "map": "portalmaze", "monster": "Time Wraith", "kills": 1 },
                            { "id": "borgars-7518-pickup", "kind": "pickupDrop", "item": "Time Fragment" }
