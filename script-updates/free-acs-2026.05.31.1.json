                        { "id": "borgars-7518-complete", "kind": "completeQuest", "questId": 7518 },
                        { "id": "borgars-7518-wait", "kind": "wait", "ms": 1000 }
                      ]
                    },
                    {
                      "id": "borgars-7517",
                      "kind": "while",
                      "condition": { "kind": "questCompleted", "amount": 7517, "not": true },
                      "actions": [
                        { "id": "borgars-7517-accept", "kind": "acceptQuest", "questId": 7517 },
