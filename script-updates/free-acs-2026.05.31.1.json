                    {
                      "id": "borgars-7521",
                      "kind": "while",
                      "condition": { "kind": "questCompleted", "amount": 7521, "not": true },
                      "actions": [
                        { "id": "borgars-7521-accept", "kind": "acceptQuest", "questId": 7521 },
                        { "id": "borgars-7521-map-item", "kind": "getMapItem", "map": "borgars", "mapItemId": 7373, "quantity": 1 },
                        { "id": "borgars-7521-complete", "kind": "completeQuest", "questId": 7521 }
