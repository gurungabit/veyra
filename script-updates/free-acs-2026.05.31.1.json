                        { "id": "borgars-7520-kale", "kind": "huntForItem", "map": "brightfortress", "monster": "Brightscythe Reaver", "itemName": "Kale", "quantity": 4 },
                        { "id": "borgars-7520-quinoa", "kind": "huntForItem", "map": "brightfortress", "monster": "Brightscythe Reaver", "itemName": "Quinoa", "quantity": 4 },
                        { "id": "borgars-7520-complete", "kind": "completeQuest", "questId": 7520 }
