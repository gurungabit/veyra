                    {
                      "id": "borgars-7522",
                      "kind": "while",
                      "condition": { "kind": "questCompleted", "amount": 7522, "not": true },
                      "actions": [
                        { "id": "borgars-7522-accept", "kind": "acceptQuest", "questId": 7522 },
                        { "id": "borgars-7522-cured", "kind": "huntForItem", "map": "borgars", "monster": "Burglinster", "itemName": "Burglinster Cured", "quantity": 1 },
                        { "id": "borgars-7522-complete", "kind": "completeQuest", "questId": 7522 }
                      ]
                    }
                  ]
                },
                {
                  "id": "free-acs-10584",
                  "kind": "while",
                  "condition": { "kind": "questCompleted", "amount": 10584, "not": true },
                  "actions": [
                    { "id": "free-acs-10584-accept", "kind": "acceptQuest", "questId": 10584 },
                    { "id": "free-acs-10584-cookie-dough", "kind": "huntForItem", "map": "borgars", "monster": "Burglinster", "itemName": "Cookie Dough", "quantity": 1 },
                    { "id": "free-acs-10584-complete", "kind": "completeQuest", "questId": 10584 }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
