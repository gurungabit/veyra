{
  "schema": 1,
  "id": "free-acs",
  "name": "Free ACs",
  "version": "2026.05.31.1",
  "scripts": [
    {
      "id": "official.free-acs",
      "name": "Free ACs",
      "description": "Completes the yearly Free ACs quest and the Borgars prerequisite story when needed.",
      "tags": ["free-acs", "acs", "borgars", "official"],
      "version": "2026.05.31.1",
      "map": "borgars",
      "actions": [
        {
          "id": "free-acs-already-done-check",
          "kind": "if",
          "condition": { "kind": "questCompleted", "amount": 10584 },
          "actions": [
            { "id": "free-acs-already-done-log", "kind": "log", "message": "Quest 10584 is already complete." }
          ],
          "elseActions": [
            {
              "id": "free-acs-level-check",
              "kind": "if",
              "condition": { "kind": "levelBelow", "amount": 20 },
              "actions": [
                { "id": "free-acs-level-log", "kind": "log", "message": "Free ACs requires level 20 and a verified email." }
              ],
              "elseActions": [
                { "id": "free-acs-warning", "kind": "log", "message": "Free ACs is a one-time quest per account. A verified email is required." },
                {
                  "id": "free-acs-borgars-check",
                  "kind": "if",
                  "condition": { "kind": "questCompleted", "amount": 7522 },
                  "actions": [
                    { "id": "free-acs-borgars-complete-log", "kind": "log", "message": "Borgars story is already complete." }
                  ],
                  "elseActions": [
                    { "id": "free-acs-borgars-start-log", "kind": "log", "message": "Completing Borgars story prerequisite." },
                    {
                      "id": "borgars-7510",
                      "kind": "while",
                      "condition": { "kind": "questCompleted", "amount": 7510, "not": true },
                      "actions": [
                        { "id": "borgars-7510-accept", "kind": "acceptQuest", "questId": 7510 },
                        { "id": "borgars-7510-lard", "kind": "huntForItem", "map": "extinction", "monster": "Lard", "itemName": "Lard", "quantity": 2 },
                        { "id": "borgars-7510-ground-beef", "kind": "huntForItem", "map": "extinction", "monster": "Freezer Drone", "itemName": "Ground Beef", "quantity": 4 },
                        { "id": "borgars-7510-complete", "kind": "completeQuest", "questId": 7510 }
                      ]
                    },
                    {
                      "id": "borgars-7511",
                      "kind": "while",
                      "condition": { "kind": "questCompleted", "amount": 7511, "not": true },
                      "actions": [
                        { "id": "borgars-7511-accept", "kind": "acceptQuest", "questId": 7511 },
                        { "id": "borgars-7511-heavy-cream", "kind": "huntForItem", "map": "battlefowl", "monster": "Chickencow", "itemName": "Heavy Cream", "quantity": 1 },
                        { "id": "borgars-7511-complete", "kind": "completeQuest", "questId": 7511 }
                      ]
                    },
                    {
                      "id": "borgars-7512",
                      "kind": "while",
                      "condition": { "kind": "questCompleted", "amount": 7512, "not": true },
