{
  "branches": ["main"],
  "tagFormat": "v${version}",
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/github",
      {
        "assets": [
          "release-assets/**/*.dmg",
          "release-assets/**/*.zip",
          "release-assets/**/*.exe",
          "release-assets/**/*.blockmap",
          "release-assets/**/latest*.yml"
        ]
      }
    ]
  ]
}
