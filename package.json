{
  "name": "veyra-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.3.0",
  "scripts": {
    "dev": "pnpm --filter @veyra/flash-client start",
    "app": "pnpm --filter @veyra/flash-client start",
    "flash:bundle": "pnpm --filter @veyra/flash-client bundle:flash",
    "stories:generate": "pnpm --filter @veyra/flash-client generate:stories",
    "flash:build-swf": "pnpm --filter @veyra/flash-client build:swf",
    "app:pack:mac": "pnpm --filter @veyra/flash-client pack:mac",
    "app:pack:win": "pnpm --filter @veyra/flash-client pack:win",
    "app:dist:mac": "pnpm --filter @veyra/flash-client dist:mac",
    "app:dist:win": "pnpm --filter @veyra/flash-client dist:win",
    "app:dist:all": "pnpm --filter @veyra/flash-client dist:all",
    "start": "pnpm --filter @veyra/flash-client start",
    "build": "pnpm -r build && pnpm script-updates:build",
    "typecheck": "pnpm -r typecheck && pnpm script-updates:typecheck",
    "test": "pnpm -r test",
    "test:e2e": "pnpm build && playwright test",
    "lint": "pnpm -r lint",
    "format": "prettier --write .",
    "release": "semantic-release",
    "release:preview": "node scripts/semantic-release-preview.mjs",
    "release:set-version": "node scripts/set-release-version.mjs",
    "script-updates:build": "node scripts/build-script-updates.mjs",
    "script-updates:typecheck": "tsc -p script-updates/tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@playwright/test": "^1.49.1",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/node": "^22.10.7",
    "esbuild": "^0.28.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "playwright": "^1.49.1",
    "prettier": "^3.4.2",
    "semantic-release": "^25.0.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^2.1.8"
  }
}
