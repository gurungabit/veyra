{
  "name": "@veyra/desktop",
  "version": "0.1.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "pnpm build:deps && pnpm build:electron && vite --host 127.0.0.1",
    "dev:renderer": "vite --host 127.0.0.1",
    "start": "pnpm build && electron .",
    "build": "pnpm build:deps && pnpm build:electron && vite build",
    "build:deps": "pnpm --filter @veyra/protocol --filter @veyra/core --filter @veyra/runtime --filter @veyra/scripts --filter @veyra/script-tools build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "typecheck": "tsc -b tsconfig.json tsconfig.electron.json",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src electron --ext .ts,.tsx"
  },
  "dependencies": {
    "@veyra/core": "workspace:*",
    "@veyra/protocol": "workspace:*",
    "@veyra/runtime": "workspace:*",
    "@veyra/script-tools": "workspace:*",
    "electron": "^33.3.1",
    "lucide-react": "^0.469.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.0.7"
  }
}
