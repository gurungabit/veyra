<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWindowsForms>true</UseWindowsForms>
    <AssemblyName>Veyra.Bridge</AssemblyName>
    <Platforms>AnyCPU;x64;x86</Platforms>
  </PropertyGroup>
  <ItemGroup>
    <Reference Include="AxInterop.ShockwaveFlashObjects">
      <HintPath>lib\AxInterop.ShockwaveFlashObjects.dll</HintPath>
      <Private>true</Private>
    </Reference>
    <Reference Include="Interop.ShockwaveFlashObjects">
      <HintPath>lib\Interop.ShockwaveFlashObjects.dll</HintPath>
      <Private>true</Private>
    </Reference>
    <None Include="..\flash-client\client.swf" Link="client.swf" CopyToOutputDirectory="PreserveNewest" Condition="Exists('..\flash-client\client.swf')" />
  </ItemGroup>
</Project>
